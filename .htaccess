# Disable directory listing
Options -Indexes

<IfModule mod_rewrite.c>
RewriteEngine On

# Live domain runs from the document root. Keep RewriteBase at / so
# clean URLs like /api/v1/login reach CodeIgniter routes correctly.
RewriteBase /

# ==========================
# ADMIN STATIC PAGES
# ==========================
# Old deployments may have root-level attendance.html/js/api.js files.
# Send users to the tracked admin folder so cache-busted assets are loaded.
RewriteRule ^$ employee-admin/attendance.html [R=302,L]
RewriteRule ^(attendance|salary|reports|staff|settings)\.html$ employee-admin/$1.html [R=302,L]
RewriteRule ^login\.html$ employee-admin/attendance.html [R=302,L]
RewriteRule ^superadmin/?$ employee-admin/superadmin/index.html [R=302,L]
RewriteRule ^superadmin/index\.html$ employee-admin/superadmin/index.html [R=302,L]
RewriteRule ^emoloyee-admin/(.*)$ employee-admin/$1 [R=302,L]

# ==========================
# REMOVE TRAILING SLASH
# ==========================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [R=301,L]

# ==========================
# FORCE NON-WWW (LIVE ONLY)
# ==========================
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
RewriteCond %{HTTP_HOST} !\.test$ [NC]
RewriteCond %{HTTP_HOST} !\.local$ [NC]
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ %{REQUEST_SCHEME}://%1%{REQUEST_URI} [R=301,L]

# ==========================
# FORCE HTTPS (LIVE ONLY)
# ==========================
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
RewriteCond %{HTTP_HOST} !\.test$ [NC]
RewriteCond %{HTTP_HOST} !\.local$ [NC]
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ==========================
# FRONT CONTROLLER (MVC / Clean URL)
# ==========================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php/$1 [L,QSA]

</IfModule>

# ==========================
# FALLBACK
# ==========================
<IfModule !mod_rewrite.c>
ErrorDocument 404 /index.php
</IfModule>

# ==========================
# SECURITY
# ==========================
ServerSignature Off
RewriteRule ^$ employee-admin/attendance.html [R=302,L]

# ==========================
# PERFORMANCE: STATIC ASSETS
# ==========================
<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType text/css "access plus 1 year"
ExpiresByType application/javascript "access plus 1 year"
ExpiresByType text/javascript "access plus 1 year"
ExpiresByType font/ttf "access plus 1 year"
ExpiresByType font/woff2 "access plus 1 year"
ExpiresByType image/png "access plus 1 year"
ExpiresByType image/jpeg "access plus 1 year"
ExpiresByType image/webp "access plus 1 year"
ExpiresByType image/svg+xml "access plus 1 year"
ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
<FilesMatch "\.(css|js|ttf|woff2|png|jpe?g|webp|svg|ico)$">
Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
<FilesMatch "\.(html)$">
Header set Cache-Control "no-cache, must-revalidate"
</FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/css application/javascript text/javascript application/json image/svg+xml
</IfModule>
