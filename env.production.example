#--------------------------------------------------------------------
# PRODUCTION .env - Copy to .env on live server and fill real values.
# 500 error is usually caused by: missing DB credentials or writable permissions.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP (optional - baseURL is auto-set from request; set only to override)
#--------------------------------------------------------------------
# app.baseURL = 'https://employee.chaychaupal.com/'

#--------------------------------------------------------------------
# DATABASE - REQUIRED ON LIVE SERVER
# Use your hosting panel (cPanel, etc.) MySQL database name, username, password.
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = your_live_database_name
database.default.username = your_live_db_username
database.default.password = your_live_db_password
database.default.DBDriver = MySQLi
database.default.port = 3306

#--------------------------------------------------------------------
# OPTIONAL
#--------------------------------------------------------------------
# encryption.key = your-32-char-hex-key-here
